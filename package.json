{
  "name": "user-management",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "docker:build": "docker build -t user-management .",
    "docker:run": "docker run -d --name user-management -p 5173:80 user-management",
    "docker:stop": "docker rm -f user-management",
    "docker:restart": "npm run docker:stop && npm run docker:run",
    "docker:start": "npm run docker:stop && npm run docker:build && npm run docker:run",
    "docker:build:fresh": "docker build --no-cache -t user-management .",
    "docker:shell": "docker exec -it user-management sh",
    "docker:inspect": "docker inspect user-management",
    "docker:ps": "docker ps",
    "docker:clean": "docker rm -f user-management && docker rmi -f user-management",
    "docker:logs": "docker logs user-management",
    "docker:images": "docker images",
    "docker:test": "npm run docker:start && npm run test:e2e",
    "docker:test:headed": "npm run docker:start && npm run test:e2e:headed",
    "docker:test:ui": "npm run docker:start && npm run test:e2e:ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "axios": "^1.18.1",
    "bootstrap": "^5.3.8",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "react-toastify": "^11.1.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "msw": "^2.14.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}